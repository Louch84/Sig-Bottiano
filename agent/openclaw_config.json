{
  "autonomy_settings": {
    "human_in_the_loop": false,
    "max_iterations": 50,
    "auto_recovery": true,
    "permission_threshold": "critical"
  },
  "execution_policy": {
    "parallel_execution": true,
    "fail_fast": false,
    "log_all_decisions": true
  },
  "safety_bounds": {
    "max_api_calls_per_run": 100,
    "blocked_actions": [
      "financial_transactions",
      "email_sending",
      "file_deletion"
    ]
  }
}